generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ONGOING
  ENDED
  MISSED
  DECLINED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  passwordHash   String
  outgoingCalls  CallSession[] @relation("OutgoingCalls")
  incomingCalls  CallSession[] @relation("IncomingCalls")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model CallSession {
  id         String     @id @default(cuid())
  type       CallType
  status     CallStatus @default(RINGING)
  callerId   String
  calleeId   String
  startedAt  DateTime   @default(now())
  answeredAt DateTime?
  endedAt    DateTime?
  metadata   String?
  caller     User       @relation("OutgoingCalls", fields: [callerId], references: [id])
  callee     User       @relation("IncomingCalls", fields: [calleeId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([callerId])
  @@index([calleeId])
}
