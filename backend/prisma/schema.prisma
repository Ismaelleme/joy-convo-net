generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
  BUSY
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  VIDEO
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ONGOING
  ENDED
  MISSED
  DECLINED
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum NotificationType {
  MESSAGE
  CALL
  EVENT
  COMMUNITY
  SYSTEM
}

// ─── User ────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  name          String
  passwordHash  String
  avatar        String?
  bio           String?
  phone         String?    @unique
  phoneVerified Boolean    @default(false)
  status        UserStatus @default(OFFLINE)
  lastSeenAt    DateTime?

  // Relations
  sentMessages     Message[]       @relation("SentMessages")
  chatMembers      ChatMember[]
  contacts         Contact[]       @relation("UserContacts")
  contactOf        Contact[]       @relation("ContactOf")
  outgoingCalls    CallSession[]   @relation("OutgoingCalls")
  incomingCalls    CallSession[]   @relation("IncomingCalls")
  feedPosts        FeedPost[]
  postLikes        PostLike[]
  postComments     PostComment[]
  events           ScheduleEvent[]
  communities      CommunityMember[]
  ownedCommunities Community[]     @relation("CommunityOwner")
  marketProducts   MarketProduct[]
  notifications    Notification[]
  aiConversations  AIConversation[]
  settings         UserSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Chat ────────────────────────────────────────────

model Chat {
  id        String   @id @default(uuid())
  name      String?
  isGroup   Boolean  @default(false)
  avatar    String?

  members  ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMember {
  id       String  @id @default(uuid())
  chatId   String
  userId   String
  isAdmin  Boolean @default(false)
  isPinned Boolean @default(false)
  isMuted  Boolean @default(false)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id       String        @id @default(uuid())
  chatId   String
  senderId String
  content  String
  type     MessageType   @default(TEXT)
  status   MessageStatus @default(SENT)
  replyToId String?
  fileUrl  String?

  chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies Message[] @relation("MessageReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([senderId])
}

// ─── Contacts ────────────────────────────────────────

model Contact {
  id        String  @id @default(uuid())
  userId    String
  contactId String
  nickname  String?
  isFavorite Boolean @default(false)
  isBlocked  Boolean @default(false)

  user    User @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contact User @relation("ContactOf", fields: [contactId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contactId])
  @@index([userId])
}

// ─── Calls ───────────────────────────────────────────

model CallSession {
  id         String     @id @default(uuid())
  type       CallType
  status     CallStatus @default(RINGING)
  callerId   String
  calleeId   String
  startedAt  DateTime   @default(now())
  answeredAt DateTime?
  endedAt    DateTime?
  duration   Int?
  metadata   String?

  caller User @relation("OutgoingCalls", fields: [callerId], references: [id])
  callee User @relation("IncomingCalls", fields: [calleeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callerId])
  @@index([calleeId])
}

// ─── Feed ────────────────────────────────────────────

model FeedPost {
  id       String  @id @default(uuid())
  authorId String
  content  String
  imageUrl String?
  isPublic Boolean @default(true)

  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    PostLike[]
  comments PostComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  userId String

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id      String @id @default(uuid())
  postId  String
  userId  String
  content String

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
}

// ─── Schedule ────────────────────────────────────────

model ScheduleEvent {
  id          String        @id @default(uuid())
  userId      String
  title       String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean       @default(false)
  priority    EventPriority @default(MEDIUM)
  status      EventStatus   @default(PENDING)
  color       String?
  reminder    Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([startDate])
}

// ─── Communities ─────────────────────────────────────

model Community {
  id          String  @id @default(uuid())
  name        String
  description String?
  avatar      String?
  isPublic    Boolean @default(true)
  ownerId     String

  owner   User              @relation("CommunityOwner", fields: [ownerId], references: [id])
  members CommunityMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityMember {
  id          String @id @default(uuid())
  communityId String
  userId      String
  role        String @default("member")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([communityId, userId])
}

// ─── Marketplace ─────────────────────────────────────

model MarketProduct {
  id          String  @id @default(uuid())
  sellerId    String
  title       String
  description String?
  price       Float
  imageUrl    String?
  category    String?
  isActive    Boolean @default(true)

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([category])
}

// ─── AI Conversations ────────────────────────────────

model AIConversation {
  id     String @id @default(uuid())
  userId String
  title  String?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AIMessage {
  id             String @id @default(uuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
}

// ─── Notifications ───────────────────────────────────

model Notification {
  id      String           @id @default(uuid())
  userId  String
  type    NotificationType
  title   String
  body    String?
  data    String?
  isRead  Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ─── User Settings ───────────────────────────────────

model UserSettings {
  id              String  @id @default(uuid())
  userId          String  @unique
  primaryColor    String  @default("#7c3aed")
  accentColor     String  @default("#06b6d4")
  language        String  @default("pt-BR")
  notifications   Boolean @default(true)
  soundEnabled    Boolean @default(true)
  darkMode        Boolean @default(true)
  fontSize        String  @default("medium")
  privacy         String  @default("public")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}
